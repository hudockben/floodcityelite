# ---------------------------------------------------------------------------
# Flood City Elite — environment configuration
# Copy this file to `.env.local` and fill in the values below.
# ---------------------------------------------------------------------------

# Neon Postgres connection string.
# Neon console -> Project -> "Connect" -> copy the "Pooled connection" string.
# It looks like:
#   postgresql://<user>:<password>@<host>-pooler.<region>.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=

# Secret used to sign the login session cookie (JWT).
# Generate a strong random value, e.g.:  openssl rand -base64 32
SESSION_SECRET=

# Optional — the default admin account created by `npm run db:setup`.
# Change these before seeding, or change the password after first login.
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=FloodCity2026!
